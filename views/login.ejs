<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-50">

  <!-- Navbar -->
  <%- include("layout/publicNavbar.ejs") %>

  <section class="min-h-[90vh]">

    <div class="max-w-7xl mx-auto px-6 py-16">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->

        <div>

          <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-medium">
            #1 Job Portal Platform
          </span>

          <h1 class="text-6xl font-bold mt-6 leading-tight">
            Build Your
            <span class="text-blue-600">
              Career
            </span>
            With Confidence
          </h1>

          <p class="mt-6 text-xl text-slate-600">
            Discover thousands of opportunities from top companies.
          </p>

          <div class="grid grid-cols-3 gap-6 mt-10">

            <div>
              <h3 class="text-3xl font-bold text-blue-600">
                10K+
              </h3>
              <p class="text-slate-500">
                Jobs
              </p>
            </div>

            <div>
              <h3 class="text-3xl font-bold text-blue-600">
                5K+
              </h3>
              <p class="text-slate-500">
                Companies
              </p>
            </div>

            <div>
              <h3 class="text-3xl font-bold text-blue-600">
                50K+
              </h3>
              <p class="text-slate-500">
                Candidates
              </p>
            </div>

          </div>

        </div>

        <!-- Right Side -->

        <div>

          <div class="bg-white rounded-3xl shadow-xl p-10">

            <h2 class="text-3xl font-bold text-center">
              Welcome Back
            </h2>

            <p class="text-center text-slate-500 mt-2 mb-8">
              Login to continue your career journey
            </p>

            <% if (error) { %>
            <div class="mb-4 p-4 bg-red-100 text-red-700 rounded-xl">
              <%= error %>
            </div>
            <% } %>

            <% if (success) { %>
            <div class="mb-4 p-4 bg-green-100 text-green-700 rounded-xl">
              <%= success %>
            </div>
            <% } %>

            <form action="/job-portal/login" method="POST" class="space-y-5">

              <div>

                <label class="block mb-2 font-medium text-slate-700">
                  Email Address
                </label>

                <input type="email" name="email" value="<%= oldData?.email || '' %>" placeholder="Enter your email" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <div>

                <label class="block mb-2 font-medium text-slate-700">
                  Password
                </label>

                <div class="relative">

                  <input type="password" id="password" name="password" placeholder="Enter your password" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600 pr-12">

                  <button type="button" onclick="togglePassword()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500">

                    <i class="fa-regular fa-eye"></i>

                  </button>

                </div>

              </div>

              <div class="flex justify-end">

                <a href="/job-portal/forgot-password" class="text-blue-600 hover:text-blue-700 text-sm font-medium">

                  Forgot Password?

                </a>

              </div>

              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-semibold transition">

                Login

              </button>

            </form>

            <div class="mt-8 text-center">

              <p class="text-slate-500">
                Don't have an account?
              </p>

              <div class="flex gap-3 mt-4">

                <a href="/job-portal/candidate/register" class="flex-1 bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl font-medium">

                  User Register

                </a>

                <a href="/job-portal/employer/register" class="flex-1 bg-purple-600 hover:bg-purple-700 text-white py-3 rounded-xl font-medium">

                  Employer Register

                </a>

              </div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </section>

  <script>
    function togglePassword() {
      const password = document.getElementById("password");

      if (password.type === "password") {
        password.type = "text";
      } else {
        password.type = "password";
      }
    }
  </script>

</body>

</html>