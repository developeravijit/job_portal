<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Company</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="flex">

    <%- include("layout/employeerSidebar.ejs") %>

    <main class="flex-1 p-8">

      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">
          Create Company
        </h1>

        <p class="text-gray-500 mt-2">
          Add your company details to start posting jobs.
        </p>
      </div>

      <!-- Error Message -->
      <% if (error) { %>
      <div class="mb-6 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg">
        <%= error %>
      </div>
      <% } %>

      <!-- Success Message -->
      <% if (success) { %>
      <div class="mb-6 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
        <%= success %>
      </div>
      <% } %>

      <!-- Form Card -->
      <div class="bg-white rounded-2xl shadow-lg p-8 max-w-4xl">

        <form action="/employer/dashboard/create/company" method="POST">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Company Name -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Company Name
              </label>

              <input type="text" name="companyName" placeholder="Enter company name" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>

            <!-- Industry -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Industry
              </label>

              <input type="text" name="industry" placeholder="Software, Finance, Healthcare..." class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>

            <!-- Website -->
            <div class="md:col-span-2">
              <label class="block text-gray-700 font-medium mb-2">
                Website
              </label>

              <input type="url" name="website" placeholder="https://example.com" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>

          </div>

          <!-- Buttons -->
          <div class="mt-8 flex gap-4">

            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium">

              Create Company

            </button>

            <a href="/employer/dashboard/myCompany" class="bg-gray-500 hover:bg-gray-600 text-white px-8 py-3 rounded-lg font-medium">

              Cancel

            </a>

          </div>

        </form>

      </div>

    </main>

  </div>

</body>

</html>