<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Manage Candidates</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-thumb {
      background: #7c3aed;
      border-radius: 20px;
    }

    body {
      overflow: hidden;
    }
  </style>

</head>

<body class="bg-black">

  <div class="flex h-screen">

    <!-- Sidebar -->
    <%- include("layout/adminNavbar.ejs") %>

    <!-- Main Content -->
    <div class="flex-1 overflow-y-auto bg-zinc-950">

      <div class="p-8">

        <!-- Heading -->

        <div class="flex justify-between items-center mb-8">

          <div>

            <h1 class="text-4xl font-bold text-white">
              Candidate Management
            </h1>

            <p class="text-zinc-400 mt-2">
              View and manage all registered candidates.
            </p>

          </div>

          <div class="bg-purple-600 px-6 py-3 rounded-xl">

            <p class="text-white font-semibold">
              Total Candidates :
              <%= totalCandidates %>
            </p>

          </div>

        </div>

        <!-- Search -->

        <!-- Search -->

        <div class="mb-8">

          <form action="/admin/dashboard/candidates" method="GET" class="flex gap-4">

            <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by name or email..." class="flex-1 bg-zinc-900 border border-zinc-800 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-purple-500">

            <button type="submit" class="px-8 py-4 bg-purple-600 hover:bg-purple-700 rounded-xl text-white font-semibold transition">

              Search

            </button>

          </form>

        </div>

        <!-- Candidate Grid -->

        <div class="grid grid-cols-3 gap-6">

          <% candidates.forEach(candidate => { %>

          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden hover:border-purple-500 transition duration-300 hover:-translate-y-1">

            <!-- Top Section -->
            <div class="bg-gradient-to-r from-purple-700 to-indigo-700 h-24 relative">

              <div class="absolute left-1/2 transform -translate-x-1/2 top-10">

                <% if(candidate.avatar){ %>

                <img src="<%= candidate.avatar %>" class="w-28 h-28 rounded-full border-4 border-zinc-900 object-cover">

                <% } else { %>

                <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(candidate.name) %>&background=7c3aed&color=ffffff&size=256" class="w-28 h-28 rounded-full border-4 border-zinc-900">

                <% } %>

              </div>

            </div>

            <!-- Body -->
            <div class="pt-20 pb-6 px-6">

              <div class="text-center">

                <h2 class="text-2xl font-bold text-white">

                  <%= candidate.name %>

                </h2>

                <p class="text-zinc-400 text-sm break-all mt-1">

                  <%= candidate.email %>

                </p>

              </div>

              <!-- Information -->

              <div class="mt-8 space-y-4">

                <div class="flex justify-between">

                  <span class="text-zinc-500">
                    Phone
                  </span>

                  <span class="text-white">

                    <%= candidate.phone || "Not Available" %>

                  </span>

                </div>

                <div class="flex justify-between">

                  <span class="text-zinc-500">
                    Role
                  </span>

                  <span class="bg-blue-600/20 text-blue-300 px-3 py-1 rounded-full text-xs capitalize">

                    <%= candidate.role %>

                  </span>

                </div>

                <div class="flex justify-between">

                  <span class="text-zinc-500">
                    Status
                  </span>

                  <% if(candidate.status){ %>

                  <span class="bg-green-600/20 text-green-300 px-3 py-1 rounded-full text-xs">

                    Active

                  </span>

                  <% } else { %>

                  <span class="bg-red-600/20 text-red-300 px-3 py-1 rounded-full text-xs">

                    Inactive

                  </span>

                  <% } %>

                </div>

                <div class="flex justify-between">

                  <span class="text-zinc-500">
                    Verified
                  </span>

                  <% if(candidate.isVerified){ %>

                  <span class="bg-emerald-600/20 text-emerald-300 px-3 py-1 rounded-full text-xs">

                    Verified

                  </span>

                  <% } else { %>

                  <span class="bg-yellow-600/20 text-yellow-300 px-3 py-1 rounded-full text-xs">

                    Pending

                  </span>

                  <% } %>

                </div>

                <div class="flex justify-between">

                  <span class="text-zinc-500">
                    Joined
                  </span>

                  <span class="text-white text-sm">

                    <%= new Date(candidate.createdAt).toLocaleDateString("en-IN") %>

                  </span>

                </div>

              </div>

              <!-- Buttons -->

              <div class="grid grid-cols-2 gap-3 mt-8">

                <a href="/admin/candidate/<%= candidate._id %>" class="bg-purple-600 hover:bg-purple-700 text-center py-3 rounded-xl text-white font-semibold">

                  View

                </a>

                <a href="/admin/delete-candidate/<%= candidate._id %>" onclick="return confirm('Delete this candidate?')" class="bg-red-600 hover:bg-red-700 text-center py-3 rounded-xl text-white font-semibold">

                  Delete

                </a>

              </div>

            </div>

          </div>

          <% }) %>

        </div>

        <!-- Empty -->

        <% if(candidates.length===0){ %>

        <div class="text-center mt-24">

          <h2 class="text-3xl text-zinc-500">
            No Candidates Found
          </h2>

        </div>

        <% } %>

        <!-- Pagination -->

        <% if(totalPages>1){ %>

        <div class="flex justify-center mt-12 gap-3">

          <% if(currentPage>1){ %>

          <a href="?page=<%= currentPage-1 %>" class="px-5 py-2 bg-zinc-800 rounded-lg text-white hover:bg-purple-600">

            Previous

          </a>

          <% } %>

          <% for(let i=1;i<=totalPages;i++){ %>

          <a href="?page=<%= i %>" class="px-5 py-2 rounded-lg <%= currentPage===i ? 'bg-purple-600 text-white':'bg-zinc-800 text-zinc-300' %>">

            <%= i %>

          </a>

          <% } %>

          <% if(currentPage<totalPages){ %>

          <a href="?page=<%= currentPage+1 %>" class="px-5 py-2 bg-zinc-800 rounded-lg text-white hover:bg-purple-600">

            Next

          </a>

          <% } %>

        </div>

        <% } %>

      </div>

    </div>

  </div>

</body>

</html>