<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Registration</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-black min-h-screen flex items-center justify-center py-10">

  <!-- Background Effects -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-purple-700 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-700 rounded-full blur-3xl opacity-20"></div>
  </div>

  <div class="relative z-10 w-full max-w-lg">

    <!-- Card -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-r from-purple-600 to-blue-600 flex items-center justify-center shadow-lg">
          <span class="text-white text-3xl font-bold">A</span>
        </div>
      </div>

      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-white">
          Create Admin Account
        </h1>
        <p class="text-zinc-400 mt-2">
          Register a new administrator account
        </p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-3 rounded-xl bg-red-500/10 border border-red-500 text-red-400">
        <%= error %>
      </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="mb-4 p-3 rounded-xl bg-green-500/10 border border-green-500 text-green-400">
        <%= success %>
      </div>
      <% } %>

      <form action="/admin/dashboard/register" method="POST" class="space-y-5">

        <!-- Name -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Full Name
          </label>

          <input type="text" name="name" value="<%= oldData?.name || '' %>" placeholder="Enter full name" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-purple-500">
        </div>

        <!-- Email -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Admin Email
          </label>

          <input type="email" name="email" value="<%= typeof oldData !== 'undefined' ? oldData.email : '' %>" placeholder="admin@example.com" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-purple-500">
        </div>

        <!-- Phone -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Phone Number
          </label>

          <input type="text" name="phone" value="<%= oldData?.phone || '' %>" placeholder="XXXXX XXXXX" class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-purple-500">
        </div>

        <!-- Password -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Password
          </label>

          <div class="relative">
            <input type="password" id="password" name="password" placeholder="Create password" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl pr-12 focus:outline-none focus:border-purple-500">

            <button type="button" onclick="togglePassword('password')" class="absolute right-4 top-3 text-zinc-400">
              👁
            </button>
          </div>
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Confirm Password
          </label>

          <div class="relative">
            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl pr-12 focus:outline-none focus:border-purple-500">

            <button type="button" onclick="togglePassword('confirmPassword')" class="absolute right-4 top-3 text-zinc-400">
              👁
            </button>
          </div>
        </div>

        <!-- Role -->
        <div>
          <label class="block text-zinc-300 mb-2 text-sm">
            Role
          </label>

          <input type="text" value="admin" readonly class="w-full bg-zinc-800 border border-zinc-700 text-purple-400 font-semibold px-4 py-3 rounded-xl">
        </div>

        <!-- Button -->
        <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
          Create Admin Account
        </button>

      </form>

      <!-- Footer -->
      <div class="mt-8 text-center border-t border-zinc-800 pt-6">

        <p class="text-zinc-500 text-sm mb-3">
          Already registered?
        </p>

        <a href="/admin/dashboard/login" class="inline-block px-6 py-3 border border-purple-500 text-purple-400 rounded-xl hover:bg-purple-500 hover:text-white transition">
          Admin Login
        </a>

      </div>

    </div>

  </div>

  <script>
    function togglePassword(id) {
      const input = document.getElementById(id);

      input.type =
        input.type === "password" ?
        "text" :
        "password";
    }
  </script>

</body>

</html>