<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-100">

  <!-- Navbar -->
  <%- include("layout/navbar.ejs") %>

  <div class="max-w-7xl mx-auto px-6 py-8">

    <!-- Search -->
    <div class="bg-white p-5 rounded-2xl shadow mb-6">

      <form action="/dashboard/user/home" method="GET" class="flex gap-3">

        <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by title, skills, location..." class="flex-1 border border-slate-300 rounded-xl px-4 py-3 outline-none focus:border-blue-500">

        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 rounded-xl font-medium">
          <i class="fa-solid fa-magnifying-glass mr-2"></i>
          Search
        </button>

      </form>

    </div>

    <!-- Job Layout -->

    <div class="flex gap-6 h-[calc(100vh-180px)]">

      <!-- Left Side Jobs -->
      <div class="w-1/3 overflow-y-auto">

        <% jobs.forEach(job => { %>

        <a href="/dashboard/user/home?jobId=<%= job._id %>&search=<%= search || '' %>" class="inline-block w-full p-4 rounded-xl shadow mb-3 border transition
 <%= selectedJob && selectedJob._id.toString() === job._id.toString()
 ? 'border-blue-600 bg-blue-50'
 : 'bg-white hover:border-blue-400'
 %>">

          <h3 class="font-bold text-lg">
            <%= job.title %>
          </h3>

          <p class="text-sm text-slate-600 mt-2">
            ₹ <%= job.salary %>
          </p>

          <p class="text-sm text-slate-600 mt-1">
            <i class="fa-solid fa-location-dot"></i>
            <%= job.location %>
          </p>

          <div class="mt-3 flex flex-wrap gap-2">

            <% if(job.skills){ %>

            <% job.skills.split(",").forEach(skill => { %>

            <span class="bg-blue-100 text-blue-700 text-xs px-2 py-1 rounded-full">
              <%= skill.trim() %>
            </span>

            <% }) %>

            <% } %>

          </div>

        </a>

        <% }) %>

      </div>

      <!-- Right Side Details -->
      <div class="w-2/3 overflow-y-auto">

        <% if(selectedJob){ %>

        <div class="bg-white p-6 rounded-xl shadow">

          <div class="flex justify-between items-start">

            <div>

              <h2 class="text-3xl font-bold text-slate-800">
                <%= selectedJob.title %>
              </h2>

              <p class="text-lg text-slate-600 mt-1">
                <%= selectedJob.company?.companyName || "Company" %>
              </p>

              <div class="flex flex-wrap gap-5 mt-4 text-sm text-slate-500">

                <span>
                  <i class="fa-solid fa-location-dot mr-1"></i>
                  <%= selectedJob.location %>
                </span>

                <span>
                  <i class="fa-solid fa-indian-rupee-sign mr-1"></i>
                  <%= selectedJob.salary %>
                </span>

                <span>
                  <i class="fa-solid fa-briefcase mr-1"></i>
                  <%= selectedJob.jobType || "Full Time" %>
                </span>

              </div>

            </div>

            <div class="flex gap-3">

              <% if(selectedJob.isSaved){ %>

              <button class="border border-yellow-500 text-yellow-600 px-4 py-3 rounded-xl" disabled>
                <i class="fa-solid fa-bookmark"></i>
              </button>

              <% } else { %>

              <form action="/candidate/save-job/<%= selectedJob._id %>" method="POST">

                <button type="submit" class="border border-slate-300 hover:border-yellow-500 hover:text-yellow-600 px-4 py-3 rounded-xl">

                  <i class="fa-regular fa-bookmark"></i>

                </button>

              </form>

              <% } %>

              <% if(selectedJob.isApplied){ %>

              <button class="bg-green-600 text-white px-6 py-3 rounded-xl font-medium" disabled>
                <i class="fa-solid fa-circle-check mr-2"></i>
                Applied
              </button>

              <% } else { %>

              <button onclick="document.getElementById('applyModal').classList.remove('hidden')" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-medium">

                <i class="fa-solid fa-paper-plane mr-2"></i>
                Apply Now

              </button>

              <% } %>

            </div>

          </div>

          <div>

            <h3 class="font-semibold text-lg mb-2">
              Job Description
            </h3>

            <p class="text-slate-700 leading-7">
              <%= selectedJob.description %>
            </p>

            <h3 class="font-semibold text-lg mt-8 mb-3">
              Required Skills
            </h3>

            <div class="flex flex-wrap gap-2">

              <% if(selectedJob.skills){ %>

              <% selectedJob.skills.split(",").forEach(skill => { %>

              <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm">
                <%= skill.trim() %>
              </span>

              <% }) %>

              <% } %>

            </div>

            <hr class="my-6">

            <h3 class="font-semibold text-lg mb-3">
              Employer Details
            </h3>

            <div class="space-y-2">

              <div class="flex justify-between">
                <div>
                  <p>
                    <strong>Name:</strong>
                    <%= selectedJob.employeer?.name || "N/A" %>
                  </p>

                  <p>
                    <strong>Email:</strong>
                    <%= selectedJob.employeer?.email || "N/A" %>
                  </p>
                </div>

                <div>
                  <p>
                    <strong>Company:</strong>
                    <%= selectedJob.company?.companyName || "N/A" %>
                  </p>

                  <p>
                    <strong>Website:</strong>
                    <%= selectedJob.company?.website || "N/A" %>
                  </p>
                </div>
              </div>

            </div>



          </div>

          <% } %>

        </div>

      </div>

    </div>

    <% if(selectedJob && !selectedJob.isApplied){ %>

    <div id="applyModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">

      <div class="bg-white p-6 rounded-xl w-full max-w-md">

        <div class="flex justify-between items-center mb-4">

          <h3 class="text-xl font-semibold">
            Apply for <%= selectedJob.title %>
          </h3>

          <button type="button" onclick="document.getElementById('applyModal').classList.add('hidden')">
            ✕
          </button>

        </div>

        <form action="/candidate/apply/job/<%= selectedJob._id %>" method="POST" enctype="multipart/form-data">

          <label class="block mb-2 font-medium">
            Upload Resume
          </label>

          <input type="file" name="resume" required accept=".pdf,.doc,.docx" class="w-full border rounded-lg p-3">

          <button type="submit" class="w-full mt-4 bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg">

            Submit Application

          </button>

        </form>

      </div>

    </div>

    <% } %>

</body>

</html>