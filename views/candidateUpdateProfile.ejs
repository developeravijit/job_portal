<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-100">

  <%- include("layout/navbar.ejs") %>

  <div class="max-w-5xl mx-auto px-6 py-8">

    <div class="bg-white rounded-2xl shadow p-8">

      <div class="flex items-center w-full gap-6 mb-8">

        <div class="text-center w-full">

          <h1 class="text-3xl text-center font-bold">
            My Profile
          </h1>

          <p class="text-slate-500 capitalize text-center">
            Update your profile information
          </p>

        </div>

      </div>


      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-lg">
        <%= error %>
      </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="mb-4 p-3 bg-green-100 text-green-700 rounded-lg">
        <%= success %>
      </div>
      <% } %>


      <form action="/candidate/profile/update" method="POST" enctype="multipart/form-data">

        <div class="grid md:grid-cols-2 gap-6">

          <div class="md:col-span-2">

            <label class="block mb-2 font-medium">
              Profile Picture
            </label>

            <div class="flex items-center gap-5">

              <% if(user.avatar){ %>

              <img id="avatarPreview" src="<%= user.avatar %>" class="w-24 h-24 rounded-full object-cover border">

              <% } else { %>

              <img id="avatarPreview" src="https://placehold.co/96x96/e2e8f0/64748b?text=User" class="w-24 h-24 rounded-full object-cover border">

              <% } %>

              <input type="file" id="avatar" name="avatar" accept="image/*" class="border rounded-xl p-3">

            </div>

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Full Name
            </label>

            <input type="text" name="name" value="<%= user.name %>" class="w-full capitalize border rounded-xl p-3">

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Email
            </label>

            <input type="email" value="<%= user.email %>" readonly class="w-full border rounded-xl p-3 bg-slate-100">

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Phone Number
            </label>

            <input type="number" name="phone" value="<%= user.phone || '' %>" class="w-full border rounded-xl p-3">

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Account Status
            </label>

            <input type="text" value="<%= user.status ? 'Active' : 'Inactive' %>" readonly class="w-full border rounded-xl p-3 bg-slate-100">

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Role
            </label>

            <input type="text" value="<%= user.role %>" readonly class="w-full uppercase border rounded-xl p-3 bg-slate-100">

          </div>

          <div>

            <label class="block mb-2 font-medium">
              Email Verification
            </label>

            <input type="text" value="<%= user.isVerified ? 'Verified' : 'Not Verified' %>" readonly class="w-full border rounded-xl p-3 bg-slate-100">

          </div>

        </div>

        <div class="mt-8 flex gap-3">

          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl">

            Update Profile

          </button>

          <a href="/candidate/profile" class="bg-slate-200 hover:bg-slate-300 px-8 py-3 rounded-xl">

            Cancel

          </a>

        </div>

      </form>

    </div>

  </div>

  <script>
    const avatarInput = document.getElementById("avatar");
    const avatarPreview = document.getElementById("avatarPreview");

    avatarInput.addEventListener("change", function() {

      const file = this.files[0];

      if (!file) return;

      const reader = new FileReader();

      reader.onload = function(e) {
        avatarPreview.src = e.target.result;
      };

      reader.readAsDataURL(file);

    });
  </script>

</body>

</html>