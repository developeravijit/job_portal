<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JobPortal - Find Your Dream Job</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-50">

  <!-- Navbar -->
 <%- include("layout/publicNavbar.ejs") %>

  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-700 to-indigo-700 text-white">

    <div class="max-w-7xl mx-auto px-6 py-24">

      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight">
            Find Your
            <span class="text-yellow-300">
              Dream Job
            </span>
            Faster
          </h1>

          <p class="mt-6 text-lg text-blue-100">
            Discover thousands of opportunities from top companies.
            Build your career with confidence.
          </p>

          <div class="mt-8 flex gap-4">

            <a href="/dashboard/user/register" class="bg-white text-blue-700 px-8 py-4 rounded-xl font-semibold">
              Get Started
            </a>

            <a href="#jobs" class="border border-white px-8 py-4 rounded-xl font-semibold">
              Browse Jobs
            </a>

          </div>

        </div>

        <div>

          <div class="bg-white p-6 rounded-2xl shadow-xl">

            <form action="/" method="GET">

              <div class="grid md:grid-cols-3 gap-4">

                <input type="text" placeholder="Job title or skill" class="border rounded-lg p-3 text-black">

                <input type="text" placeholder="Location" class="border rounded-lg p-3 text-black">

                <button class="bg-blue-600 text-white rounded-lg p-3 hover:bg-blue-700">
                  Search Jobs
                </button>

              </div>

            </form>

          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- Statistics -->
  <section class="py-16">

    <div class="max-w-7xl mx-auto px-6">

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-white p-8 rounded-2xl shadow text-center">
          <h3 class="text-4xl font-bold text-blue-600">
            <%= totalJobs || 0 %>+
          </h3>
          <p class="mt-2 text-slate-600">
            Active Jobs
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow text-center">
          <h3 class="text-4xl font-bold text-blue-600">
            <%= totalCompanies || 0 %>+
          </h3>
          <p class="mt-2 text-slate-600">
            Companies
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow text-center">
          <h3 class="text-4xl font-bold text-blue-600">
            10K+
          </h3>
          <p class="mt-2 text-slate-600">
            Candidates
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow text-center">
          <h3 class="text-4xl font-bold text-blue-600">
            5K+
          </h3>
          <p class="mt-2 text-slate-600">
            Placements
          </p>
        </div>

      </div>

    </div>

  </section>

  <!-- Featured Jobs -->
  <section id="jobs" class="py-16">

    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center mb-12">

        <h2 class="text-4xl font-bold">
          Latest Opportunities
        </h2>

        <p class="text-slate-500 mt-3">
          Explore the newest jobs from top employers
        </p>

      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <% jobs.forEach(job=>{ %>

        <div class="bg-white rounded-2xl p-6 shadow hover:shadow-xl transition">

          <h3 class="text-xl font-bold">
            <%= job.title %>
          </h3>

          <p class="text-slate-600 mt-2">
            <i class="fa-solid fa-location-dot"></i>
            <%= job.location %>
          </p>

          <p class="text-green-600 font-semibold mt-2">
            ₹ <%= job.salary %>
          </p>

          <p class="mt-4 text-slate-500 line-clamp-3">
            <%= job.description %>
          </p>

          <a href="/dashboard/login" class="mt-5 inline-block bg-blue-600 text-white px-5 py-2 rounded-lg">
            Apply Now
          </a>

        </div>

        <% }) %>

      </div>

    </div>

  </section>

  <!-- Why Choose Us -->
  <section id="about" class="bg-white py-20">

    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center mb-14">

        <h2 class="text-4xl font-bold">
          Why Choose Us
        </h2>

      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <div class="p-8 bg-slate-50 rounded-2xl">

          <i class="fa-solid fa-shield text-4xl text-blue-600"></i>

          <h3 class="text-xl font-bold mt-4">
            Verified Companies
          </h3>

          <p class="mt-3 text-slate-600">
            Only trusted and verified employers.
          </p>

        </div>

        <div class="p-8 bg-slate-50 rounded-2xl">

          <i class="fa-solid fa-bolt text-4xl text-blue-600"></i>

          <h3 class="text-xl font-bold mt-4">
            Easy Application
          </h3>

          <p class="mt-3 text-slate-600">
            Apply for jobs in just one click.
          </p>

        </div>

        <div class="p-8 bg-slate-50 rounded-2xl">

          <i class="fa-solid fa-briefcase text-4xl text-blue-600"></i>

          <h3 class="text-xl font-bold mt-4">
            Career Growth
          </h3>

          <p class="mt-3 text-slate-600">
            Find opportunities that match your goals.
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- CTA -->
  <section class="bg-blue-600 text-white py-20">

    <div class="max-w-4xl mx-auto text-center px-6">

      <h2 class="text-5xl font-bold">
        Start Your Career Journey Today
      </h2>

      <p class="mt-6 text-xl">
        Join thousands of professionals finding their next opportunity.
      </p>

      <a href="/dashboard/user/register" class="inline-block mt-8 bg-white text-blue-600 px-8 py-4 rounded-xl font-bold">
        Create Free Account
      </a>

    </div>

  </section>

  <!-- Footer -->
  <footer class="bg-slate-900 text-white py-12">

    <div class="max-w-7xl mx-auto px-6">

      <div class="grid md:grid-cols-4 gap-8">

        <div>

          <h3 class="text-2xl font-bold">
            JobPortal
          </h3>

          <p class="mt-3 text-slate-400">
            Your trusted platform for career growth.
          </p>

        </div>

        <div>
          <h4 class="font-semibold mb-3">Company</h4>

          <ul class="space-y-2 text-slate-400">
            <li>About</li>
            <li>Contact</li>
            <li>Careers</li>
          </ul>
        </div>

        <div>
          <h4 class="font-semibold mb-3">Support</h4>

          <ul class="space-y-2 text-slate-400">
            <li>Help Center</li>
            <li>Terms</li>
            <li>Privacy Policy</li>
          </ul>
        </div>

        <div>
          <h4 class="font-semibold mb-3">Follow Us</h4>

          <div class="flex gap-4 text-2xl">
            <i class="fab fa-facebook"></i>
            <i class="fab fa-linkedin"></i>
            <i class="fab fa-github"></i>
          </div>
        </div>

      </div>

      <hr class="my-8 border-slate-700">

      <p class="text-center text-slate-400">
        © 2026 JobPortal. All Rights Reserved.
      </p>

    </div>

  </footer>

</body>

</html>