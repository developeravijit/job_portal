<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/your-kit.js" crossorigin="anonymous"></script>

  <title>All Companies</title>
</head>

<body class="bg-zinc-950 min-h-screen">

  <div class="flex">

    <%- include("layout/adminNavbar.ejs") %>

    <main class="flex-1 p-8">

      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-center gap-5 mb-8">

        <div>
          <h1 class="text-4xl font-bold text-white">
            Companies
          </h1>

          <p class="text-zinc-400 mt-2">
            Total Companies :
            <span class="text-purple-400 font-semibold">
              <%= totalCompanies %>
            </span>
          </p>
        </div>

        <!-- Search -->
        <form action="/admin/dashboard/companies" method="GET">

          <div class="flex items-center gap-3">

            <input type="text" name="search" value="<%= search %>" placeholder="Search company..." class="bg-zinc-900 border border-zinc-800 rounded-xl px-5 py-3 text-white outline-none w-72">

            <button class="bg-purple-700 hover:bg-purple-800 text-white px-5 py-3 rounded-xl">
              Search
            </button>

          </div>

        </form>

      </div>

      <!-- Companies Grid -->
      <% if(companies.length > 0){ %>

      <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-6">

        <% companies.forEach(company=>{ %>

        <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 hover:border-purple-700 duration-300">

          <!-- Logo -->
          <div class="w-16 h-16 rounded-2xl bg-purple-700 flex items-center justify-center text-3xl text-white font-bold mb-5">

            <%= company.companyName.charAt(0).toUpperCase() %>

          </div>

          <!-- Company Name -->
          <h2 class="text-2xl font-bold text-white">
            <%= company.companyName %>
          </h2>

          <p class="text-zinc-400 mt-1">
            <%= company.industry || "No Industry" %>
          </p>

          <div class="border-t border-zinc-800 my-5"></div>

          <!-- Details -->
          <div class="space-y-3">

            <div class="flex items-center justify-between">
              <span class="text-zinc-400">
                Employer
              </span>

              <span class="text-white font-medium">
                <%= company.employerName || "N/A" %>
              </span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-zinc-400">
                Email
              </span>

              <span class="text-white text-sm">
                <%= company.employerEmail || "N/A" %>
              </span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-zinc-400">
                Website
              </span>

              <% if(company.website){ %>

              <a href="<%= company.website %>" target="_blank" class="text-purple-400 hover:underline">
                Visit
              </a>

              <% }else{ %>

              <span class="text-white">
                N/A
              </span>

              <% } %>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-zinc-400">
                Total Jobs
              </span>

              <span class="bg-purple-700 text-white px-3 py-1 rounded-full text-sm">
                <%= company.totalJobs %>
              </span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-zinc-400">
                Created
              </span>

              <span class="text-white text-sm">
                <%= new Date(company.createdAt).toLocaleDateString() %>
              </span>
            </div>

          </div>

        </div>

        <% }) %>

      </div>

      <% } else { %>

      <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-12 text-center">

        <h2 class="text-2xl font-bold text-white">
          No Companies Found
        </h2>

        <p class="text-zinc-400 mt-3">
          There are no companies available right now.
        </p>

      </div>

      <% } %>

      <!-- Pagination -->
      <% if(totalPages > 1){ %>

      <div class="flex justify-center items-center gap-3 mt-10">

        <% if(currentPage > 1){ %>

        <a href="/admin/dashboard/companies?page=<%= currentPage-1 %>&search=<%= search %>" class="bg-zinc-800 text-white px-4 py-2 rounded-lg">
          Previous
        </a>

        <% } %>

        <% for(let i=1;i<=totalPages;i++){ %>

        <a href="/admin/dashboard/companies?page=<%= i %>&search=<%= search %>" class="<%= currentPage === i ? 'bg-purple-700 text-white' : 'bg-zinc-800 text-zinc-300' %> px-4 py-2 rounded-lg">
          <%= i %>
        </a>

        <% } %>

        <% if(currentPage < totalPages){ %>

        <a href="/admin/dashboard/companies?page=<%= currentPage+1 %>&search=<%= search %>" class="bg-zinc-800 text-white px-4 py-2 rounded-lg">
          Next
        </a>

        <% } %>

      </div>

      <% } %>

    </main>

  </div>

</body>

</html>