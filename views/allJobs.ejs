<!DOCTYPE html>
<html>

<head>
  <title>All Jobs</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="flex">

    <%- include("layout/employeerSidebar.ejs") %>

    <main class="flex-1 p-8">

      <h1 class="text-3xl font-bold mb-8">
        My Jobs
      </h1>

      <div class="bg-white p-4 rounded-lg shadow mb-6">
        <form action="/employer/dashboard/jobs" method="GET">
          <div class="flex gap-3">
            <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by title, skills, location..." class="flex-1 border rounded-lg px-4 py-2 outline-none focus:ring-2 focus:ring-blue-500" />

            <input type="hidden" name="limit" value="<%= limit %>">

            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
              Search
            </button>

            <% if (search) { %>
            <a href="/employer/dashboard/jobs" class="bg-gray-500 text-white px-6 py-2 rounded-lg">
              Clear
            </a>
            <% } %>
          </div>
        </form>
      </div>

      <div class="mb-5">
        <p class="text-gray-600">
          Total Jobs: <span class="font-semibold"><%= itemCount %></span>
        </p>
      </div>

      <% if (jobs && jobs.length > 0) { %>

      <div class="grid grid-cols-2 gap-5">

        <% jobs.forEach(job => { %>

        <div class="bg-white p-6 rounded shadow">

          <h2 class="text-xl font-bold capitalize">
            <%= job.title %>
          </h2>

          <p class="my-3 text-gray-600 capitalize">
            <%= job.description.length > 120
      ? job.description.substring(0, 120) + "..."
      : job.description
  %>
          </p>

          <p class="uppercase">
            <strong class="capitalize">Skills:</strong>
            <%= job.skills %>
          </p>

          <p class="uppercase">
            <strong class="capitalize">Salary:</strong>
            ₹<%= job.salary %>
          </p>

          <p class="capitalize">
            <strong>Location:</strong>
            <%= job.location %>
          </p>

          <div class="mt-4 flex gap-2">
            <a href="/employer/dashboard/job/<%= job._id %>" class="bg-blue-600 text-white px-4 py-2 rounded">
              View
            </a>

            <a href="/employer/dashboard/job/edit/<%= job._id %>" class="bg-yellow-500 text-white px-4 py-2 rounded">
              Edit
            </a>

            <form action="/employer/dashboard/job/delete/<%= job._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this job?')">

              <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg">

                Delete Job

              </button>

            </form>
          </div>

        </div>

        <% }) %>

      </div>

      <% if (pageCount > 1) { %>
      <nav class="mt-8 flex items-center justify-center gap-2">
        <% if (pages && pages.length) { %>
        <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>&limit=<%= limit %>&search=<%= search || '' %>" class="px-4 py-2 bg-white border rounded hover:bg-gray-50">Previous</a>
        <% } %>

        <% pages.forEach(page => { %>
        <a href="?page=<%= page.number %>&limit=<%= limit %>&search=<%= search || '' %>" class="px-4 py-2 border rounded <%= page.number === Number(currentPage) ? 'bg-blue-600 text-white' : 'bg-white hover:bg-gray-50' %>"><%= page.number %></a>
        <% }) %>

        <% if (currentPage < pageCount) { %>
        <a href="?page=<%= currentPage + 1 %>&limit=<%= limit %>&search=<%= search || '' %>" class="px-4 py-2 bg-white border rounded hover:bg-gray-50">Next</a>
        <% } %>
        <% } %>
      </nav>
      <% } %>

      <% } else { %>

      <div class="bg-white p-10 rounded shadow text-center">

        <% if (search) { %>

        <h2 class="text-2xl font-bold text-gray-600">
          No jobs found for "<%= search %>"
        </h2>

        <a href="/employer/dashboard/jobs" class="inline-block mt-4 bg-blue-600 text-white px-5 py-2 rounded">
          View All Jobs
        </a>

        <% } else { %>

        <h2 class="text-2xl font-bold text-gray-600">
          No Jobs Created Yet
        </h2>

        <p class="mt-3 text-gray-500">
          Create your first job posting.
        </p>

        <a href="/employer/dashboard/create/job" class="inline-block mt-4 bg-blue-600 text-white px-5 py-2 rounded">
          Create Job
        </a>

        <% } %>

      </div>

      <% } %>

    </main>

  </div>

</body>

</html>