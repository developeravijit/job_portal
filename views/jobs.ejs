<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Manage Jobs</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-thumb {
      background: #7c3aed;
      border-radius: 20px;
    }

    body {
      overflow: hidden;
    }
  </style>
</head>

<body class="bg-black">

  <div class="flex h-screen">

    <%- include("layout/adminNavbar.ejs") %>

    <div class="flex-1 overflow-y-auto bg-zinc-950">

      <div class="p-8">

        <!-- Header -->
        <div class="flex justify-between items-center mb-8">

          <div>
            <h1 class="text-4xl font-bold text-white">
              Job Management
            </h1>

            <p class="text-zinc-400 mt-2">
              View and manage all posted jobs.
            </p>
          </div>

          <div class="bg-purple-600 px-6 py-3 rounded-xl">
            <p class="text-white font-semibold">
              Total Jobs :
              <%= totalJobs %>
            </p>
          </div>

        </div>

        <!-- Search -->
        <div class="mb-8">

          <form action="/admin/dashboard/jobs" method="GET" class="flex gap-4">

            <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by title or company..." class="flex-1 bg-zinc-900 border border-zinc-800 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-purple-500">

            <button type="submit" class="px-8 py-4 bg-purple-600 hover:bg-purple-700 rounded-xl text-white font-semibold">
              Search
            </button>

          </form>

        </div>

        <!-- Jobs Grid -->
        <div class="grid lg:grid-cols-3 gap-6">

          <% jobs.forEach(job => { %>

          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 hover:border-purple-500 transition">

            <div class="flex justify-between items-start">

              <div>

                <h2 class="text-2xl font-bold text-white">
                  <%= job.title %>
                </h2>

                <p class="text-zinc-400 mt-1">
                  <%= job.companyName || "No Company" %>
                </p>

              </div>

              <% if(job.status){ %>

              <span class="bg-green-600/20 text-green-300 px-3 py-1 rounded-full text-xs">
                Active
              </span>

              <% } else { %>

              <span class="bg-red-600/20 text-red-300 px-3 py-1 rounded-full text-xs">
                Closed
              </span>

              <% } %>

            </div>

            <div class="border-t border-zinc-800 my-5"></div>

            <div class="space-y-4">

              <div class="flex justify-between">
                <span class="text-zinc-500">Location</span>
                <span class="text-white">
                  <%= job.location || "N/A" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-zinc-500">Salary</span>
                <span class="text-white">
                  ₹ <%= job.salary || "Not Mentioned" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-zinc-500">Experience</span>
                <span class="text-white">
                  <%= job.experience || "N/A" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-zinc-500">Employer</span>
                <span class="text-white">
                  <%= job.employerName || "N/A" %>
                </span>
              </div>

              <div class="flex justify-between">
                <span class="text-zinc-500">Posted</span>
                <span class="text-white text-sm">
                  <%= new Date(job.createdAt).toLocaleDateString("en-IN") %>
                </span>
              </div>

            </div>

            <div class="grid grid-cols-2 gap-3 mt-8">

              <a href="/admin/dashboard/jobs/<%= job._id %>" class="bg-purple-600 hover:bg-purple-700 text-center py-3 rounded-xl text-white font-semibold">

                View

              </a>

              <a href="/admin/dashboard/jobs/delete/<%= job._id %>" onclick="return confirm('Delete this job?')" class="bg-red-600 hover:bg-red-700 text-center py-3 rounded-xl text-white font-semibold">

                Delete

              </a>

            </div>

          </div>

          <% }) %>

        </div>

        <!-- Empty State -->
        <% if(jobs.length === 0){ %>

        <div class="text-center mt-24">

          <h2 class="text-3xl text-zinc-500">
            No Jobs Found
          </h2>

        </div>

        <% } %>

        <!-- Pagination -->
        <% if(totalPages > 1){ %>

        <div class="flex justify-center mt-12 gap-3">

          <% if(currentPage > 1){ %>

          <a href="?page=<%= currentPage-1 %>&search=<%= search %>" class="px-5 py-2 bg-zinc-800 rounded-lg text-white hover:bg-purple-600">

            Previous

          </a>

          <% } %>

          <% for(let i=1;i<=totalPages;i++){ %>

          <a href="?page=<%= i %>&search=<%= search %>" class="px-5 py-2 rounded-lg <%= currentPage===i ? 'bg-purple-600 text-white':'bg-zinc-800 text-zinc-300' %>">

            <%= i %>

          </a>

          <% } %>

          <% if(currentPage < totalPages){ %>

          <a href="?page=<%= currentPage+1 %>&search=<%= search %>" class="px-5 py-2 bg-zinc-800 rounded-lg text-white hover:bg-purple-600">

            Next

          </a>

          <% } %>

        </div>

        <% } %>

      </div>

    </div>

  </div>

</body>

</html>