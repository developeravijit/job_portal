<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-black min-h-screen flex items-center justify-center">

  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-72 h-72 bg-purple-700 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-0 right-0 w-72 h-72 bg-blue-700 rounded-full blur-3xl opacity-20"></div>
  </div>

  <div class="relative z-10 w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-3xl shadow-2xl p-8">

    <!-- Logo -->
    <div class="flex justify-center mb-6">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-r from-purple-600 to-blue-600 flex items-center justify-center">
        <span class="text-white text-2xl font-bold">A</span>
      </div>
    </div>

    <!-- Heading -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">
        Admin Portal
      </h1>
      <p class="text-zinc-400 mt-2">
        Sign in to access the dashboard
      </p>
    </div>

    <!-- Error -->
    <% if (error) { %>
    <div class="mb-4 p-3 bg-red-500/10 border border-red-500 text-red-400 rounded-lg">
      <%= error %>
    </div>
    <% } %>

    <!-- Success -->
    <% if (success) { %>
    <div class="mb-4 p-3 bg-green-500/10 border border-green-500 text-green-400 rounded-lg">
      <%= success %>
    </div>
    <% } %>

    <form action="/admin/login" method="POST" class="space-y-5">

      <!-- Email -->
      <div>
        <label class="block text-zinc-300 mb-2 text-sm">
          Admin Email
        </label>

        <input type="email" name="email" placeholder="admin@example.com" value="<%= typeof oldData !== 'undefined' ? oldData.email : '' %>" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-purple-500">
      </div>

      <!-- Password -->
      <div>
        <label class="block text-zinc-300 mb-2 text-sm">
          Password
        </label>

        <div class="relative">
          <input id="password" type="password" name="password" placeholder="Enter password" required class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 rounded-xl pr-12 focus:outline-none focus:border-purple-500">

          <button type="button" onclick="togglePassword()" class="absolute right-4 top-3 text-zinc-400">
            👁
          </button>
        </div>
      </div>

      <!-- Admin Register -->
      <div class="flex align-center justify-between">
        <div class="text-left">
          <a href="/admin/register-page" class="text-sm text-purple-400 hover:text-purple-300">
            Admin Register
          </a>
        </div>

        <!-- Forgot Password -->
        <div class="text-right">
          <a href="/admin/forgot-password" class="text-sm text-purple-400 hover:text-purple-300">
            Forgot Password?
          </a>
        </div>

      </div>
      <!-- Login Button -->
      <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold hover:opacity-90 transition">
        Login as Admin
      </button>

    </form>

    <!-- Security Notice -->
    <div class="mt-8 p-4 bg-zinc-800 rounded-xl border border-zinc-700">
      <div class="flex items-center gap-2">
        <span class="text-green-400">●</span>
        <span class="text-zinc-300 text-sm">
          Secure Admin Authentication
        </span>
      </div>
      <p class="text-zinc-500 text-xs mt-2">
        Authorized administrators only.
      </p>
    </div>

    <!-- Back to User Login -->
    <div class="text-center mt-6">
      <a href="/dashboard/login" class="text-zinc-400 hover:text-white text-sm">
        ← Back to User Login
      </a>
    </div>

  </div>

  <script>
    function togglePassword() {
      const password = document.getElementById("password");

      password.type =
        password.type === "password" ?
        "text" :
        "password";
    }
  </script>

</body>

</html>