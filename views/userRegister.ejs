<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

</head>


<body class="bg-slate-50">

  <%- include("layout/publicNavbar.ejs") %>

  <section class="min-h-[90vh]">

    <div class="max-w-7xl mx-auto px-6 py-16">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left Side -->

        <div>

          <span class="bg-green-100 text-green-700 px-4 py-2 rounded-full text-sm font-medium">
            Join Thousands Of Professionals
          </span>

          <h1 class="text-6xl font-bold mt-6 leading-tight">

            Start Your
            <span class="text-blue-600">
              Career Journey
            </span>

            Today

          </h1>

          <p class="mt-6 text-xl text-slate-600">
            Create your account, apply for jobs, connect with top employers,
            and build your future.
          </p>

          <div class="grid grid-cols-3 gap-6 mt-10">

            <div>
              <h3 class="text-3xl font-bold text-blue-600">10K+</h3>
              <p class="text-slate-500">Jobs</p>
            </div>

            <div>
              <h3 class="text-3xl font-bold text-blue-600">5K+</h3>
              <p class="text-slate-500">Companies</p>
            </div>

            <div>
              <h3 class="text-3xl font-bold text-blue-600">50K+</h3>
              <p class="text-slate-500">Candidates</p>
            </div>

          </div>

        </div>

        <!-- Right Side -->

        <div>

          <div class="bg-white rounded-3xl shadow-xl p-10">

            <h2 class="text-3xl font-bold text-center">
              Create Account
            </h2>

            <p class="text-center text-slate-500 mt-2 mb-8">
              Register and start applying for jobs
            </p>

            <% if(error){ %>
            <div class="mb-4 p-4 bg-red-100 text-red-700 rounded-xl">
              <%= error %>
            </div>
            <% } %>

            <% if(success){ %>
            <div class="mb-4 p-4 bg-green-100 text-green-700 rounded-xl">
              <%= success %>
            </div>
            <% } %>

            <form action="/job-portal/candidate/register" method="POST" class="space-y-5">

              <div>

                <label class="block mb-2 font-medium">
                  Full Name
                </label>

                <input type="text" name="name" value="<%= oldData?.name || '' %>" placeholder="Enter your full name" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <div>

                <label class="block mb-2 font-medium">
                  Email Address
                </label>

                <input type="email" name="email" value="<%= oldData?.email || '' %>" placeholder="Enter your email" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <div>

                <label class="block mb-2 font-medium">
                  Phone Number
                </label>

                <input type="number" name="phone" value="<%= oldData?.phone || '' %>" placeholder="Enter your phone number" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <div>

                <label class="block mb-2 font-medium">
                  Password
                </label>

                <input type="password" name="password" placeholder="Create password" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <div>

                <label class="block mb-2 font-medium">
                  Confirm Password
                </label>

                <input type="password" name="confirmPassword" placeholder="Confirm password" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-600">

              </div>

              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-semibold transition">

                Create Account

              </button>

            </form>

            <div class="mt-8 text-center">

              <p class="text-slate-500">
                Already have an account?
              </p>

              <a href="/job-portal/login" class="inline-block mt-3 text-blue-600 font-semibold hover:text-blue-700">

                Login Here

              </a>

            </div>

          </div>

        </div>

      </div>

    </div>

  </section>

</body>


</html>