```ejs
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saved Jobs</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-100">

  <%- include("layout/navbar.ejs") %>

  <div class="max-w-7xl mx-auto px-6 py-8">

    <div class="flex justify-between items-center mb-8">

      <div>
        <h1 class="text-3xl font-bold text-slate-800">
          Saved Jobs
        </h1>

        <p class="text-slate-500 mt-1">
          Total Saved Jobs: <%= itemCount %>
        </p>
      </div>

    </div>

    <% if(jobs.length > 0){ %>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

      <% jobs.forEach(job => { %>

      <div class="bg-white rounded-2xl shadow-sm border hover:shadow-md transition p-5">

        <div class="flex justify-between items-start">

          <h2 class="text-xl font-semibold text-slate-800">
            <%= job.title %>
          </h2>

          <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-medium">
            Saved
          </span>

        </div>

        <p class="text-slate-600 mt-3">
          <i class="fa-solid fa-building mr-2"></i>
          <%= job.employeerName || "Employer" %>
        </p>

        <p class="text-slate-600 mt-2">
          <i class="fa-solid fa-location-dot mr-2"></i>
          <%= job.location %>
        </p>

        <p class="text-slate-600 mt-2">
          <i class="fa-solid fa-indian-rupee-sign mr-2"></i>
          <%= job.salary %>
        </p>

        <div class="flex flex-wrap gap-2 mt-4">

          <% if(job.skills){ %>

          <% job.skills.split(",").forEach(skill => { %>

          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded-full text-xs">
            <%= skill.trim() %>
          </span>

          <% }) %>

          <% } %>

        </div>

        <div class="mt-5 pt-4 border-t">

          <a href="/dashboard/user/home?jobId=<%= job.jobID %>" class="w-full inline-block text-center bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl">

            View Job

          </a>

        </div>

      </div>

      <% }) %>

    </div>

    <% } else { %>

    <div class="bg-white rounded-2xl p-12 text-center shadow-sm">

      <i class="fa-regular fa-bookmark text-5xl text-slate-300 mb-4"></i>

      <h2 class="text-2xl font-semibold text-slate-700">
        No Saved Jobs
      </h2>

      <p class="text-slate-500 mt-2">
        Save jobs to view them later.
      </p>

      <a href="/dashboard/user/home" class="inline-block mt-6 bg-blue-600 text-white px-6 py-3 rounded-xl">

        Browse Jobs

      </a>

    </div>

    <% } %>

    <% if(pageCount > 1){ %>

    <div class="flex justify-center mt-10 gap-2">

      <% for(let i = 1; i <= pageCount; i++){ %>

      <a href="?page=<%= i %>" class="px-4 py-2 rounded-lg border
        <%= currentPage === i
        ? 'bg-blue-600 text-white border-blue-600'
        : 'bg-white text-slate-700'
        %>">

        <%= i %>

      </a>

      <% } %>

    </div>

    <% } %>

  </div>

</body>

</html>
```