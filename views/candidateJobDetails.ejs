<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Job Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
  <div class="flex">
    <%- include("layout/userSidebar.ejs") %>

    <main class="flex-1 p-8">
      <div class="bg-white rounded-lg shadow p-8">
        <h1 class="text-3xl font-bold mb-4"><%= job.title %></h1>
        <p class="text-gray-600 mb-4"><%= job.description %></p>
        <div class="grid gap-4 md:grid-cols-2 mb-6">
          <div>
            <p><strong>Skills:</strong> <%= job.skills %></p>
            <p><strong>Location:</strong> <%= job.location %></p>
            <p><strong>Salary:</strong> ₹<%= job.salary %></p>
          </div>
          <div>
            <p><strong>Employer:</strong> <%= job.employeerName || "Not available" %></p>
            <p><strong>Email:</strong> <%= job.employeerEmail || "-" %></p>
            <p><strong>Phone:</strong> <%= job.employeerPhone || "-" %></p>
          </div>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex flex-wrap gap-3">
            <a href="/candidate/jobs" class="px-4 py-2 rounded bg-gray-600 text-white">Back to jobs</a>
            <form action="/api/application/save-job/<%= job._id %>" method="POST">
              <button type="submit" class="px-4 py-2 rounded bg-green-600 text-white">Save Job</button>
            </form>
          </div>

          <div class="bg-gray-50 p-4 rounded">
            <h2 class="text-xl font-semibold mb-3">
              Apply for this job
            </h2>

            <% if (isApplied) { %>

            <div class="bg-green-100 border border-green-300 text-green-700 p-3 rounded">
              ✓ You have already applied for this job
            </div>

            <button type="button" disabled class="mt-3 px-4 py-2 rounded bg-gray-500 text-white">
              Applied
            </button>

            <% } else { %>

            <form action="/candidate/apply/job/<%= job._id %>" method="POST" enctype="multipart/form-data" class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700">
                  Upload Resume
                </label>

                <input type="file" name="resume" accept=".pdf" required class="mt-2 block w-full text-sm text-gray-700">


              </div>

              <button type="submit" class="px-4 py-2 rounded bg-purple-600 text-white">
                Apply Now
              </button>
            </form>

            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>

</html>