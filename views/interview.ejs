<!DOCTYPE html>
<html>

<head>
  <title>Interview Candidates</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="flex">

    <%- include("layout/employeerSidebar.ejs") %>

    <main class="flex-1 p-8">

      <h1 class="text-3xl font-bold mb-2">
        Interview Candidates
      </h1>

      <p class="text-gray-500 mb-8">
        Selected candidates ready for interview
      </p>

      <% if(hasData){ %>

      <div class="grid gap-6">

        <% interviews.forEach(candidate => { %>

        <div class="bg-white rounded-xl shadow p-6">

          <div class="flex justify-between">

            <div>

              <h2 class="text-xl font-bold">
                <%= candidate.candidateName %>
              </h2>

              <p class="text-gray-600">
                <%= candidate.candidateEmail %>
              </p>

              <p class="text-gray-600">
                <%= candidate.candidatePhone %>
              </p>

              <p class="mt-3">
                <strong>Job:</strong>
                <%= candidate.jobTitle %>
              </p>

            </div>

            <% if(candidate.status === "selected"){ %>

            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full h-fit">
              Selected
            </span>

            <% } else { %>

            <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full h-fit">
              Rejected
            </span>

            <% } %>

          </div>

          <div class="mt-6 border-t pt-4 flex gap-3">

            <% if(candidate.status === "selected"){ %>

            <form action="/employer/notification/<%= candidate.candidateID %>">

              <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg">
                Send Interview Email
              </button>

            </form>

            <form action="/employer/application/status/<%= candidate.applicationID %>" method="POST">

              <input type="hidden" name="status" value="rejected">

              <input type="hidden" name="redirectTo" value="<%= req.originalUrl %>">

              <button type="submit" class="bg-red-600 text-white px-5 py-2 rounded-lg">
                Reject
              </button>

            </form>

            <% } else { %>

            <span class="bg-red-100 text-red-700 px-4 py-2 rounded-lg font-medium">
              Candidate Rejected
            </span>

            <% } %>

          </div>

        </div>

        <% }) %>

      </div>

      <% } else { %>

      <div class="bg-white p-10 rounded-xl shadow text-center">

        <h2 class="text-2xl font-bold">
          No Candidates Found
        </h2>

      </div>

      <% } %>

      <% if(pageCount > 1){ %>

      <div class="flex justify-center mt-8 gap-2">

        <% for(let i = 1; i <= pageCount; i++){ %>

        <% if(i === currentPage){ %>

        <span class="px-4 py-2 bg-blue-600 text-white rounded">
          <%= i %>
        </span>

        <% } else { %>

        <a href="/employer/interviews?page=<%= i %>" class="px-4 py-2 bg-white border rounded">

          <%= i %>

        </a>

        <% } %>

        <% } %>

      </div>

      <% } %>

    </main>

  </div>

</body>

</html>