<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Job</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="flex">

    <%- include("layout/employeerSidebar.ejs") %>

    <main class="flex-1 p-8">

      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">
          Post New Job
        </h1>

        <p class="text-gray-500 mt-2">
          Create a new job posting to attract candidates.
        </p>
      </div>

      <!-- Error Message -->
      <% if (error) { %>
      <div class="mb-6 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg">
        <%= error %>
      </div>
      <% } %>

      <!-- Success Message -->
      <% if (success) { %>
      <div class="mb-6 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
        <%= success %>
      </div>
      <% } %>

      <!-- Form -->
      <div class="bg-white rounded-2xl shadow-lg p-8 max-w-5xl">

        <form action="/employeer/create/job" method="POST">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Job Title -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Job Title
              </label>

              <input type="text" name="title" placeholder="Backend Developer" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>

            <!-- Salary -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Salary (Annual)
              </label>

              <input type="number" name="salary" placeholder="600000" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>

            <!-- Skills -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Required Skills
              </label>

              <input type="text" name="skills" placeholder="Node.js, Express.js, MongoDB" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>

            <!-- Location -->
            <div>
              <label class="block text-gray-700 font-medium mb-2">
                Job Location
              </label>

              <input type="text" name="location" placeholder="Kolkata, India" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none" required>
            </div>

            <!-- Description -->
            <div class="md:col-span-2">
              <label class="block text-gray-700 font-medium mb-2">
                Job Description
              </label>

              <textarea name="description" rows="8" placeholder="Describe the job responsibilities, requirements, benefits, etc." class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none resize-none" required></textarea>
            </div>

          </div>

          <!-- Buttons -->
          <div class="mt-8 flex gap-4">

            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium">

              Post Job

            </button>

            <a href="/employeer/jobs" class="bg-gray-500 hover:bg-gray-600 text-white px-8 py-3 rounded-lg font-medium">

              Cancel

            </a>

          </div>

        </form>

      </div>

    </main>

  </div>

</body>

</html>