
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Candidate Profile</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="bg-slate-100">

  <%- include("layout/navbar.ejs") %>

  <div class="max-w-5xl mx-auto px-6 py-8">

    <div class="bg-white rounded-3xl shadow overflow-hidden">

      <!-- Cover -->

      <div class="h-40 bg-gradient-to-r from-blue-600 to-indigo-700"></div>

      <div class="px-8 pb-8">

        <!-- Profile Header -->

        <div class="-mt-16 flex justify-between items-start">

          <div class="flex items-center gap-5">

            <% if(user.avatar){ %>

            <img src="<%= user.avatar %>" alt="Profile" class="w-32 h-32 rounded-full border-4 border-white object-cover shadow-lg">

            <% } else { %>

            <div class="w-32 h-32 rounded-full bg-white border-4 border-white shadow-lg flex items-center justify-center">

              <i class="fa-solid fa-user text-5xl text-blue-600"></i>

            </div>

            <% } %>

            <div class="mt-12">

              <h1 class="text-3xl uppercase font-bold text-slate-800">
                <%= user.name %>
              </h1>

              <p class="text-slate-500 mt-1">
                Candidate
              </p>

            </div>

          </div>

          <a href="/candidate/profile/update" class="mt-20 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl">

            <i class="fa-solid fa-pen-to-square mr-2"></i>
            Edit Profile

          </a>

        </div>

        <!-- Information -->

        <div class="grid md:grid-cols-2 gap-6 mt-10">

          <div class="bg-slate-50 rounded-2xl p-6">

            <h3 class="font-semibold text-lg mb-5">
              Personal Information
            </h3>

            <div class="space-y-4">

              <p class="capitalize">
                <strong>Name:</strong>
                <%= user.name %>
              </p>

              <p>
                <strong>Email:</strong>
                <%= user.email %>
              </p>

              <p>
                <strong>Phone:</strong>
                <%= user.phone || "Not Added" %>
              </p>

            </div>

          </div>

          <div class="bg-slate-50 rounded-2xl p-6">

            <h3 class="font-semibold text-lg mb-5">
              Account Information
            </h3>

            <div class="space-y-4">

              <p>
                <strong>Role:</strong>
                <span class="capitalize">
                  <%= user.role %>
                </span>
              </p>

              <p>
                <strong>Status:</strong>

                <% if(user.status){ %>

                <span class="text-green-600 font-medium">
                  Active
                </span>

                <% } else { %>

                <span class="text-red-600 font-medium">
                  Inactive
                </span>

                <% } %>

              </p>

              <p>
                <strong>Email Verification:</strong>

                <% if(user.isVerified){ %>

                <span class="text-green-600 font-medium">
                  Verified
                </span>

                <% } else { %>

                <span class="text-red-600 font-medium">
                  Not Verified
                </span>

                <% } %>

              </p>

            </div>

          </div>

        </div>

        <!-- Joined Date -->

        <div class="bg-slate-50 rounded-2xl p-6 mt-6">

          <h3 class="font-semibold text-lg mb-4">
            Membership Details
          </h3>

          <p>
            <strong>Joined:</strong>

            <%= new Date(user.createdAt).toLocaleDateString("en-IN", {
              day: "numeric",
              month: "long",
              year: "numeric"
            }) %>

          </p>

        </div>

      </div>

    </div>

  </div>

</body>

</html>